# Google Gemini API Key (for embeddings + LLM)
# Get it from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Pinecone API Key (for vector database)
# Get it from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here

# Groq API Key (optional, for Groq model support)
# Get it from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# For Vercel deployment, set the same variables in Project Settings > Environment Variables.
